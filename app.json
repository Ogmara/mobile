{
  "expo": {
    "name": "Ogmara",
    "slug": "ogmara",
    "version": "0.4.5",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ogmara",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.ogmara.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Ogmara uses Face ID to unlock the app and protect your wallet."
      }
    },
    "android": {
      "package": "org.ogmara.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
